# Virtual Environment
.venv/
env/
venv/
ENV/

# Python artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# Django sensitive files
db.sqlite3
.env

# Media and Static (generated at runtime / served from S3)
/static/
/media/
